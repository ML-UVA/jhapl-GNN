path = "/p/mlatuva/jhu-graph/sidhya/jhapl-GNN/inrun/models/data/top5_k1.csv"
df = pd.read_csv(path)

# Build edges (pre → post)
edges = list(zip(df["pre_id"], df["post_id"]))

# 🔥 IMPORTANT FIX: convert to simple graph (remove duplicates)
edges = list(set(edges))

num_edges = len(edges)
print("Unique edges (|E|):", num_edges)

swap_ratio = 2.0
print("Swaps per graph:", int(swap_ratio * num_edges))


# ───────────────────────────────────────────────────────────────
# 2. X-swap (degree-preserving randomization)
# ───────────────────────────────────────────────────────────────

def xswap_directed(edges, swap_ratio=2.0, seed=None):
    if seed is not None:
        random.seed(seed)

    edge_set = set(edges)
    edge_list = list(edge_set)

    n_swaps = int(swap_ratio * len(edge_list))
    successful_swaps = 0

    while successful_swaps < n_swaps:
        i = random.randrange(len(edge_list))
        j = random.randrange(len(edge_list))

        if i == j:
            continue

        a, b = edge_list[i]
        c, d = edge_list[j]

        # Must be 4 distinct nodes for standard swap
        if len({a, b, c, d}) != 4:
            continue

        new_e1 = (a, d)
        new_e2 = (c, b)

        # Validate BOTH edges before applying
        if (
            a != d and c != b and
            new_e1 not in edge_set and
            new_e2 not in edge_set
        ):
            # Apply swap atomically
            edge_set.remove((a, b))
            edge_set.remove((c, d))

            edge_set.add(new_e1)
            edge_set.add(new_e2)

            edge_list[i] = new_e1
            edge_list[j] = new_e2

            successful_swaps += 1

    return list(edge_set)


# ───────────────────────────────────────────────────────────────
# 3. Degree check (must be TRUE now)
# ───────────────────────────────────────────────────────────────

def degree_sequence(edges):
    deg = defaultdict(lambda: {"in": 0, "out": 0})
    for s, t in edges:
        deg[s]["out"] += 1
        deg[t]["in"] += 1
    return dict(deg)

def verify_degree_preserved(original, perturbed):
    return degree_sequence(original) == degree_sequence(perturbed)


# ───────────────────────────────────────────────────────────────
# 4. Generate + SAVE graphs
# ───────────────────────────────────────────────────────────────

save_dir = "/p/mlatuva/jhu-graph/sidhya/jhapl-GNN/inrun/models/data/null_graphs"
os.makedirs(save_dir, exist_ok=True)

n_graphs = 10

for i in range(n_graphs):
    print(f"\nGenerating graph {i+1}/{n_graphs}...")

    g = xswap_directed(edges, swap_ratio=swap_ratio, seed=i)

    ok = verify_degree_preserved(edges, g)
    print("Degree preserved:", ok)

    if not ok:
        print("⚠️ ERROR: Degree not preserved — stop and debug")
        break

    df_g = pd.DataFrame(g, columns=["source", "target"])
    save_path = f"{save_dir}/null_graph_{i}.csv"
    df_g.to_csv(save_path, index=False)

    print(f"Saved to: {save_path}")


# ───────────────────────────────────────────────────────────────
