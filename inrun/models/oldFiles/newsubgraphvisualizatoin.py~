import pickle
import numpy as np
import pandas as pd
import networkx as nx
import matplotlib.pyplot as plt

print("loading shapley values")
shap = pickle.load(open("graph_node_shapley_normalized.value", "rb"))

node_ids = shap["node_index"]
shap_vals = shap["Normalized Shapley (%)"]

shap_map = {}
for i in range(len(node_ids)):
    shap_map[node_ids[i]] = shap_vals[i]

print("loading graph")
df = pd.read_csv("data/top5_k1.csv")

G = nx.Graph()
for u, v in zip(df.pre_id, df.post_id):
    G.add_edge(u, v)

print("graph nodes", G.number_of_nodes())
print("graph edges", G.number_of_edges())

# -------- greedy expansion --------

def greedy_motif(seed, G, shap_map, K):
    used = set()
    order = []

    used.add(seed)
    order.append(seed)

    while len(order) < K:
        best_node = None
        best_val = -1

        for u in order:
            for v in G.neighbors(u):
                if v in used:
                    continue
                val = shap_map.get(v, 0)
                if val > best_val:
                    best_val = val
                    best_node = v

        if best_node is None:
            break

        used.add(best_node)
        order.append(best_node)

    return order

# -------- choose seed --------

sorted_nodes = sorted(shap_map.items(), key=lambda x: x[1], reverse=True)
seed = sorted_nodes[0][0]

print("seed node", seed)

motif_nodes = greedy_motif(seed, G, shap_map, K=10)

print("motif size", len(motif_nodes))

# -------- build subgraph --------

H = G.subgraph(motif_nodes)

# -------- visualization --------

pos = nx.spring_layout(H, seed=42)

sizes = []
colors = []
labels = {}

for i in range(len(motif_nodes)):
    n = motif_nodes[i]
    sizes.append(300 + shap_map[n] * 2000)
    colors.append(shap_map[n])
    labels[n] = str(i)

plt.figure(figsize=(7, 6))

nx.draw_networkx_edges(H, pos, alpha=0.6)
nx.draw_networkx_nodes(
    H,
    pos,
    node_size=sizes,
    node_color=colors,
    cmap="hot"
)
nx.draw_networkx_labels(H, pos, labels=labels, font_size=10)

plt.title("Greedy Shapley Motif\n(node label = greedy step)")
plt.axis("off")

out = "greedy_motif.png"
plt.tight_layout()
plt.savefig(out, dpi=300)
plt.close()

print("saved", out)
