# ───────────────────────────────────────────────────────────────
# 2. X-swap (degree-preserving randomization)
# ───────────────────────────────────────────────────────────────

def xswap_directed(edges, swap_ratio=2.0, seed=None):
    if seed is not None:
        random.seed(seed)

    edge_set = set(edges)
    edge_list = list(edge_set)

    n_swaps = int(swap_ratio * len(edge_list))
    successful_swaps = 0

    while successful_swaps < n_swaps:
        i = random.randrange(len(edge_list))
        j = random.randrange(len(edge_list))

        a, b = edge_list[i]
        c, d = edge_list[j]

        # --- Standard X-swap ---
        if len({a, b, c, d}) == 4:
            new_e1 = (a, d)
            new_e2 = (c, b)

            if (
                a != d and c != b and
                new_e1 not in edge_set and
                new_e2 not in edge_set
            ):
                edge_set.remove((a, b))
                edge_set.remove((c, d))
                edge_set.add(new_e1)
                edge_set.add(new_e2)

                edge_list[i] = new_e1
                edge_list[j] = new_e2

                successful_swaps += 1

        # --- Triangle swap (bias correction) ---
        elif len({a, b, c, d}) == 3 and i != j:
            tri_nodes = list({a, b, c, d})
            if len(tri_nodes) != 3:
                continue

            u, v, w = tri_nodes

            tri_edges = [
                (x, y) for (x, y) in [
                    (u, v), (v, u),
                    (v, w), (w, v),
                    (u, w), (w, u)
                ]
                if (x, y) in edge_set
            ]

            if len(tri_edges) < 2:
                continue

            reversed_edges = [(y, x) for (x, y) in tri_edges]

            conflict = any(
                (e in edge_set and e not in tri_edges)
                for e in reversed_edges
            )

            if conflict:
                continue

            for e in tri_edges:
                edge_set.remove(e)
            for e in reversed_edges:
                edge_set.add(e)

            edge_list = list(edge_set)
            successful_swaps += 1

    return list(edge_set)


# ───────────────────────────────────────────────────────────────
# 3. Degree check (must be TRUE now)
# ───────────────────────────────────────────────────────────────

def degree_sequence(edges):
    deg = defaultdict(lambda: {"in": 0, "out": 0})
    for s, t in edges:
        deg[s]["out"] += 1
        deg[t]["in"] += 1
    return dict(deg)

def verify_degree_preserved(original, perturbed):
    return degree_sequence(original) == degree_sequence(perturbed)


# ───────────────────────────────────────────────────────────────
