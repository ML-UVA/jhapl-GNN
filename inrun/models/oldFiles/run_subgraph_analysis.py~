import pickle
import pandas as pd
import networkx as nx
import os
import random

from dotmotif import Motif
from dotmotif.executors import GrandIsoExecutor

############################################
# PATHS
############################################

REAL_CSV = "data/top5_k1.csv"
NULL_DIR = "data/null_graphs"
NULL_FILES = [
    "null_graph_0.csv",
    "null_graph_1.csv",
    "null_graph_2.csv",
    "null_graph_3.csv"
]
SUBGRAPH_RESULTS = "subgraph_results.pkl"
SUBSAMPLE_NODES = 1000
SEED = 42

############################################
# LOAD GRAPH
############################################

def build_graph_from_csv(path, n_nodes=None, seed=42):
    print(f"Loading graph from {path}", flush=True)
    
    df = pd.read_csv(path)
    
    if "pre_id" in df.columns:
        edges = zip(df["pre_id"], df["post_id"])
    else:
        edges = zip(df["source"], df["target"])
    
    G = nx.DiGraph()
    for u, v in edges:
        G.add_edge(u, v)
    
    print(f"Graph loaded: {G.number_of_nodes()} nodes, {G.number_of_edges()} edges", flush=True)

    if n_nodes is not None and G.number_of_nodes() > n_nodes:
        random.seed(seed)
        sampled_nodes = random.sample(list(G.nodes()), n_nodes)
        G = G.subgraph(sampled_nodes).copy()
        print(f"Subsampled to: {G.number_of_nodes()} nodes, {G.number_of_edges()} edges", flush=True)

    return G

############################################
# BUILD DOTMOTIF STRING
############################################

def edges_to_motif(edges):
    node_map = {}
    counter = 0
    lines = []
    for u, v in edges:
        if u not in node_map:
            node_map[u] = f"N{counter}"
            counter += 1
        if v not in node_map:
            node_map[v] = f"N{counter}"
            counter += 1
        lines.append(f"{node_map[u]} -> {node_map[v]}")
    return "\n".join(lines)

############################################
# COUNT WITH DOTMOTIF
############################################

def count_with_dotmotif(executor, motif_str):
    motif = Motif(motif_str)
    results = executor.find(motif)
    return len(results)

############################################
# STEP 1: EXTRACT MOTIF PATTERNS FROM FULL GRAPH
############################################

print("Loading subgraph results...", flush=True)
data = pickle.load(open(SUBGRAPH_RESULTS, "rb"))
real_subgraphs = data["real"]

print("\nExtracting motif definitions from full graph...", flush=True)
G_full = build_graph_from_csv(REAL_CSV)  # no subsampling, just for extracting structure

pattern_list = []
for i, (seed, score, nodes) in enumerate(real_subgraphs):
    subg = G_full.subgraph(nodes)
    edges = list(subg.edges())
    
    if len(edges) < 4:
        print(f"Motif {i}: skipping (only {len(edges)} edges)", flush=True)
        continue
    
    motif_str = edges_to_motif(edges)
    pattern_list.append((i, score, motif_str))
    print(f"Motif {i}: extracted {len(edges)} edges, shapley={score:.4f}", flush=True)
    print(motif_str, flush=True)

if not pattern_list:
    print("No valid motifs found, exiting.", flush=True)
    exit()

############################################
# STEP 2: COUNT IN SUBSAMPLED REAL GRAPH
############################################

print("\n=== REAL GRAPH COUNTS ===", flush=True)
G_real = build_graph_from_csv(REAL_CSV, n_nodes=SUBSAMPLE_NODES, seed=SEED)
executor_real = GrandIsoExecutor(graph=G_real)

real_counts = {}
for i, score, motif_str in pattern_list:
    print(f"\nCounting motif {i} in real graph...", flush=True)
    count = count_with_dotmotif(executor_real, motif_str)
    real_counts[i] = count
    print(f"[REAL motif {i}] shapley={score:.4f} count={count}", flush=True)

############################################
# STEP 3: COUNT IN SUBSAMPLED NULL GRAPHS
############################################

null_counts = {i: [] for i, _, _ in pattern_list}

for fname in NULL_FILES:
    print(f"\n=== NULL GRAPH: {fname} ===", flush=True)
    
    path = os.path.join(NULL_DIR, fname)
    G_null = build_graph_from_csv(path, n_nodes=SUBSAMPLE_NODES, seed=SEED)
    executor_null = GrandIsoExecutor(graph=G_null)
    
    for i, score, motif_str in pattern_list:
        print(f"Counting motif {i} in {fname}...", flush=True)
        count = count_with_dotmotif(executor_null, motif_str)
        null_counts[i].append(count)
        print(f"[{fname} motif {i}] count={count}", flush=True)

############################################
# STEP 4: SUMMARY
############################################

import numpy as np

print("\n=== SUMMARY ===", flush=True)
print(f"{'Motif':<8} {'Shapley':<10} {'Real':<10} {'Null Mean':<12} {'Null Std':<10} {'Z':<8} {'Expression'}", flush=True)
print("-" * 70, flush=True)

for i, score, motif_str in pattern_list:
    real = real_counts[i]
    nulls = np.array(null_counts[i])
    mu = nulls.mean()
    sd = nulls.std()
    z = (real - mu) / sd if sd > 0 else float("nan")
    expressed = "OVER" if real > mu else "UNDER"
    print(f"{i:<8} {score:<10.4f} {real:<10} {mu:<12.1f} {sd:<10.1f} {z:<8.2f} {expressed}", flush=True)

print("\nDONE", flush=True)
