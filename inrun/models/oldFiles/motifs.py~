import networkx as nx
import pandas as pd
import numpy as np
import matplotlib.pyplot as plt
import seaborn as sns
import pickle

############################################
# 1. LOAD GRAPH AS TRUE SYNAPSE GRAPH
############################################

print("Loading graph...")

df = pd.read_csv("data/top5_k1.csv")

print("CSV shape:", df.shape)
print(df.head())

G = nx.MultiDiGraph()

for _, row in df.iterrows():
    G.add_edge(int(row["pre_id"]), int(row["post_id"]))

print("Nodes:", G.number_of_nodes())
print("Edges (synapses):", G.number_of_edges())
print("Sample nodes:", list(G.nodes())[:10])
print("Graph type:", type(G))
print("Is multigraph:", G.is_multigraph())
print("Is directed:", G.is_directed())

############################################
# 2. LOAD NODE SHAPLEY VALUES
############################################

print("Loading normalized node Shapley...")

with open("graph_node_shapley_normalized.value", "rb") as f:
    shap_vals = pickle.load(f)

# Extract normalized shapley vector
shap_vals = shap_vals["Normalized Shapley (%)"]

print("Final shapley length:", len(shap_vals))
print("Type:", type(shap_vals))

# Build EXACT mapping like original Shapley computation
neuron_ids = pd.unique(df[["pre_id", "post_id"]].values.ravel())
neuron_ids = [int(x) for x in neuron_ids]

neuron_to_idx = {nid: i for i, nid in enumerate(neuron_ids)}
idx_to_neuron = {i: nid for i, nid in enumerate(neuron_ids)}

print("Shapley length:", len(shap_vals))
print("Mapping length:", len(neuron_to_idx))

############################################
# 3. HELPER FUNCTIONS
############################################

def motif_score(nodes):
    return sum(shap_vals[neuron_to_idx[n]] for n in nodes if n in neuron_to_idx)

def directed_density(H):
    n = len(H.nodes())
    if n <= 1:
        return 0
    max_edges = n * (n - 1)
    return H.number_of_edges() / max_edges

############################################
# 4. GREEDY NODE-BASED MOTIF EXTRACTION
############################################

def extract_motifs(size, top_k=3):

    used_nodes = set()
    motifs = []

    # Only use nodes that exist in shapley mapping
    valid_nodes = [n for n in G.nodes() if n in neuron_to_idx]

    sorted_nodes = sorted(
        valid_nodes,
        key=lambda n: shap_vals[neuron_to_idx[n]],
        reverse=True
    )

    for seed in sorted_nodes:
        if seed in used_nodes:
            continue

        motif_nodes = {seed}
        frontier = set(G.successors(seed)) | set(G.predecessors(seed))

        # filter frontier to valid shapley nodes
        frontier = {n for n in frontier if n in neuron_to_idx}

        while len(motif_nodes) < size and frontier:

            best = max(
                frontier,
                key=lambda n: shap_vals[neuron_to_idx[n]]
            )

            motif_nodes.add(best)

            new_neighbors = set(G.successors(best)) | set(G.predecessors(best))
            new_neighbors = {n for n in new_neighbors if n in neuron_to_idx}

            frontier |= new_neighbors
            frontier -= motif_nodes

        if len(motif_nodes) == size:
            motifs.append(motif_nodes)
            used_nodes |= motif_nodes

        if len(motifs) == top_k:
            break

    return motifs

############################################
# 5. VISUALIZATION
############################################

def visualize_motif(nodes, size, motif_id):

    H = G.subgraph(nodes).copy()

    total_score = motif_score(nodes)
    density = directed_density(H)

    print(f"\nMotif Size {size} - #{motif_id}")
    print("Total Shapley:", total_score)
    print("Directed Density:", density)
    print("Nodes:", list(nodes))

    ####################################
    # Collapse MultiDiGraph for plotting
    ####################################
    H_simple = nx.DiGraph()

    for u, v in H.edges():
        if H_simple.has_edge(u, v):
            H_simple[u][v]["weight"] += 1
        else:
            H_simple.add_edge(u, v, weight=1)

    ####################################
    # Graph plot
    ####################################
    fig, ax = plt.subplots(figsize=(10,10))

    node_colors = [shap_vals[neuron_to_idx[n]] for n in H_simple.nodes()]
    pos = nx.spring_layout(H_simple, k=1.8,  iterations=100, seed=1 )

    edge_weights = [H_simple[u][v]["weight"] for u, v in H_simple.edges()]

    labels = {n: str(i) for i, n in enumerate(H_simple.nodes())}
    
    nx.draw(
        H_simple,
        pos,
        node_color=node_colors,
        cmap="viridis",
        node_size=900,
        with_labels=False,
        width=[w * 0.7 for w in edge_weights],
        edge_color="black",
        arrowsize=20,
        ax=ax
    )
    
    nx.draw_networkx_labels(
        H_simple,
        pos,
        labels=labels,
        font_size=9,
        font_color="black"
    )
    
    sm = plt.cm.ScalarMappable(
        cmap="viridis",
        norm=plt.Normalize(
            vmin=min(shap_vals),
            vmax=max(shap_vals)
        )
    )
    sm.set_array([])

    fig.colorbar(sm, ax=ax, label="Normalized Shapley (%)")
    ax.set_title(f"Motif Size {size} - #{motif_id}")

    plt.savefig(f"motif_size{size}_{motif_id}_graph.png", dpi=300)
    plt.close()

    ####################################
    # Heatmap (true adjacency count)
    ####################################
    node_list = list(nodes)
    adj = np.zeros((len(node_list), len(node_list)))

    for u, v in H.edges():
        i = node_list.index(u)
        j = node_list.index(v)
        adj[i][j] += 1

    fig2, ax2 = plt.subplots(figsize=(5,5))
    sns.heatmap(adj, cmap="magma", square=True, ax=ax2)
    ax2.set_title(f"Adjacency Heatmap Size {size} - #{motif_id}")

    plt.savefig(f"motif_size{size}_{motif_id}_heatmap.png", dpi=300)
    plt.close()

############################################
# 6. RUN
############################################

for size in [5, 10, 20]:

    print("\n==============================")
    print(f"EXTRACTING MOTIFS SIZE {size}")
    print("==============================")

    motifs = extract_motifs(size)

    for i, nodes in enumerate(motifs):
        visualize_motif(nodes, size, i+1)

print("\nDone.")
